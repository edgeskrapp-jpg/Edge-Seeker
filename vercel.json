{
  "version": 2,
  "builds": [
    { "src": "edgeseeker-landing.html", "use": "@vercel/static" },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/landing",
      "dest": "/edgeseeker-landing.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-stats",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/update-elo",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/refresh-picks",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/refresh-picks",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/auto-run-agent",
      "schedule": "5 15 * * *"
    },
    {
      "path": "/api/cron/auto-run-agent",
      "schedule": "5 21 * * *"
    },
    {
      "path": "/api/cron/auto-log-results",
      "schedule": "0 4 * * *"
    }
  ]
}
